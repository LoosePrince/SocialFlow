# Supabase（见项目 Dashboard → Settings → API）
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# 管理员：首次写入 profiles 时若登录邮箱与此一致（不区分大小写），则角色为 admin
VITE_ADMIN_EMAIL=you@example.com

# GitHub：媒体上传（见 src/github.ts，需有仓库 contents 写入权限的 token）
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_GITHUB_USER=your_github_username
VITE_GITHUB_REPO=your_repo_name
VITE_GITHUB_UPLOAD_PATH=SocialFlow/
VITE_GITHUB_EMAIL=you@example.com