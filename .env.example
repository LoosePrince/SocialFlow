# ========== 前端（Vite，变量名以 VITE_ 开头）==========
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# 仅用于前端解析 jsDelivr 等 CDN 地址（不含密钥）
VITE_GITHUB_USER=your_github_username
VITE_GITHUB_REPO=your_repo_name
VITE_GITHUB_UPLOAD_PATH=SocialFlow/

# GitHub Actions 部署 Pages：与本地一致的值写到仓库
# Settings → Secrets and variables → Actions：
#   Secrets：VITE_SUPABASE_URL、VITE_SUPABASE_PUBLISHABLE_KEY（可选 VITE_API_URL）
#   Variables：VITE_GITHUB_USER、VITE_GITHUB_REPO、VITE_GITHUB_UPLOAD_PATH（非敏感，也可用 Secrets）

# 留空则开发时走 Vite 代理访问 http://127.0.0.1:8787 的 /api
# VITE_API_URL=http://127.0.0.1:8787

# 前端静态资源与路由根路径。本地开发留空即可（等价 /）。
# 自定义域名挂在域名根（如 https://blog.example.com/）时 CI 里设为 /；仅 github.io/<repo>/ 子路径时用 /仓库名/
# VITE_BASE_URL=/

# ========== 后端（server/index.ts，与前端分开放置时可单独 .env）==========
# Supabase → Project Settings → Database → Connection string（Session mode / pooler）
DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# 与前端同一 Supabase 项目 URL（后端验 RS256/ES256 JWT 时从 …/auth/v1/.well-known/jwks.json 拉公钥；dotenv 会加载 VITE_SUPABASE_URL）
# SUPABASE_URL=https://xxxxxxxx.supabase.co
#
# 仅当 access_token 为 Legacy HS256 时需要：Dashboard → JWT Keys → Legacy JWT secret（Reveal）
# 若项目已用「JWT Signing Keys」非对称签发，可不填，靠上方 URL + JWKS 验签
# Max PostgreSQL connections per backend process. There is also 1 extra LISTEN connection.
# DATABASE_MAX_CONNECTIONS=5

# SUPABASE_JWT_SECRET=your_jwt_secret
# 可选：与 JWT 中 iss 完全一致；不设则从 SUPABASE_URL 或 VITE_SUPABASE_URL 推导为 …/auth/v1
# SUPABASE_JWT_ISSUER=https://xxxxxxxx.supabase.co/auth/v1
# 可选：默认 audience 为 authenticated（与 Supabase 用户 access_token 一致）
# SUPABASE_JWT_AUD=authenticated

# 首次创建 profiles 时若邮箱匹配则 role=admin（不区分大小写）
ADMIN_EMAIL=you@example.com

# QQ 扫码登录：在 Dashboard → Project Settings → API 复制 service_role（仅后端，勿提交到前端）
# SUPABASE_SERVICE_ROLE_KEY=

# GitHub 媒体上传（Fine-grained token 需 contents: write）
GITHUB_TOKEN=
GITHUB_USER=your_github_username
GITHUB_REPO=your_repo_name
# 仓库内根前缀；实际文件为 {GITHUB_UPLOAD_PATH}post|project|profile/<UUID>/<crc32>.<ext>
GITHUB_UPLOAD_PATH=SocialFlow/
GITHUB_EMAIL=you@example.com

PORT=8787
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# 浏览器 Web Push（用于站点未打开时通知推送）
# 生成方式：npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# 建议使用 mailto:your-email@example.com
VAPID_SUBJECT=mailto:you@example.com

# 设为 1 或 true 时跳过启动时的 SQL 迁移（只读副本等极少数场景）
# SKIP_DB_MIGRATIONS=

# 点赞/评论计数纠偏：默认每 2 小时用 likes、comments 真实行数重写 posts/projects 上的缓存字段
# COUNT_RECONCILE_INTERVAL_MS=7200000
# SKIP_COUNT_RECONCILE=
