{
  "name": "social-flow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client",
    "build:client": "tsc && vite build",
    "build:server": "tsc -p tsconfig.server.json && node --input-type=module -e \"import fs from 'node:fs'; fs.cpSync('server/migrations','dist-server/migrations',{recursive:true});\"",
    "start": "node dist-server/index.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "@hono/node-server": "^1.19.13",
    "@supabase/supabase-js": "^2.103.0",
    "antd": "^5.12.2",
    "antd-mobile": "^5.33.0",
    "dayjs": "^1.11.10",
    "dotenv": "^17.4.1",
    "framer-motion": "^10.16.16",
    "hono": "^4.12.12",
    "jose": "^6.2.2",
    "lucide-react": "^0.294.0",
    "postgres": "^3.4.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.20.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  }
}
